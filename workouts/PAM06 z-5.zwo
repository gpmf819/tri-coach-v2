			<textevent timeoffset="90" message="cadence 90 RPM"/>
			<textevent timeoffset="120" message="cadence 100 RPM"/>
		</IntervalsT>
		<SteadyState Duration="360" Power="0.88">
			<textevent timeoffset="0" message="6 x (45 secondes assis + 15 secondes debout) / Cadence 80 RPM"/>
		</SteadyState>
		<SteadyState Duration="300" Power="0.59">
			<textevent timeoffset="0" message="cadence 100 RPM"/>
